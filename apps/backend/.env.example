# Servidor
PORT=3000

# PostgreSQL — ex: postgresql://postgres:senha@localhost:5432/flashcard_db
DATABASE_URL=postgresql://user:password@localhost:5432/flashcard_db

# Supabase — encontre em: Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # chave secreta (nunca expor no cliente)
SUPABASE_ANON_KEY=your-anon-key
